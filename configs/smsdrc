# Gammu SMS Daemon Configuration File
# https://docs.gammu.org/config/index.html#gammurc
[gammu]
port = /dev/ttyUSB0
connection = at115200
gammucoding = utf8

# Gammu SMS Daemon Configuration File
# https://docs.gammu.org/smsd/config.html
[smsd]
#unicode support
InboxFormat = unicode
OutboxFormat = unicode
TransmitFormat = unicode
#unicode support end

#database configuration
Service = SQL
Driver = sqlite3
Database = smsd.db
DBDir = /var/lib/gammu/
#database configuration end

PhoneID = modem1
CommTimeout = 5
SendTimeout = 30
MaxRetries = 5
ReceiveFrequency = 5

# Apply incoming delivery reports (ACK) to the message status in the DB.
# Messages still opt in to a report per-send via the API's "ack": true flag;
# this only controls that received reports update sentitems (Status/DeliveryDateTime).
DeliveryReport = sms

# Debugging options
LogFile = syslog
LogFormat = text
DebugLevel=255
